@using BTCPayServer.Security
@using Microsoft.AspNetCore.Mvc.TagHelpers
@model BTCPayServer.Plugins.Clink.Models.ClinkSettings
@inject BTCPayServer.Abstractions.Contracts.IScopeProvider ScopeProvider
@{
    var storeId = ScopeProvider.GetCurrentStoreId();
    ViewData["Title"] = "CLINK Lightning Configuration";
}

<div class="row">
    <div class="col-xl-8 col-lg-10">
        <form asp-action="Configure" asp-route-storeId="@storeId" method="post">
            <h2 class="mb-4">CLINK Lightning</h2>
            <p class="text-muted mb-4">
                Accept Bitcoin Lightning payments on your BTCPay Server via the CLINK protocol (clinkme.dev) over Nostr. Get your <code>nOffer</code> string from 
                <a href="https://shockwallet.app" target="_blank" rel="noopener noreferrer">ShockWallet</a>, 
                <a href="https://shockwallet.app" target="_blank" rel="noopener noreferrer">ShockWallet</a> or
                <a href="https://github.com/BareBits/electrum_clink" target="_blank" rel="noopener noreferrer">Electrum</a>. 
                Customers pay with you with 
                <a href="https://shockwallet.app" target="_blank" rel="noopener noreferrer">ShockWallet</a>,
                <a href="https://zeusln.com" target="_blank" rel="noopener noreferrer">ZEUS</a>,
                <a href="https://amethyst.social" target="_blank" rel="noopener noreferrer">Amethyst</a>
                or any other <a href="https://clinkme.dev/apps.html" target="_blank" rel="noopener noreferrer">CLINK-aware Lightning wallets</a>. <br/>
                Enable Lightning Auto-Renew Subscription payments. All communication flows over Nostr relays. No web server (HTTP/HTTPS) required for your future Lightning transactions, more private than ever.

            </p>

            @if (TempData["SuccessMessage"] is string successMsg)
            {
                <div class="alert alert-success">@successMsg</div>
            }
            @if (TempData["ErrorMessage"] is string errorMsg)
            {
                <div class="alert alert-danger">@errorMsg</div>
            }

            <div class="form-check mb-4">
                <input asp-for="Enabled" class="form-check-input" id="ClinkEnabled" />
                <label class="form-check-label" for="ClinkEnabled">Enable CLINK Lightning payments</label>
            </div>

            <div class="form-group">
                <label asp-for="Noffer"></label>
                <div class="input-group">
                    <input asp-for="Noffer" class="form-control font-monospace" placeholder="noffer1..." id="NofferInput" />
                    <button type="button" class="btn btn-outline-secondary" id="ValidateNofferBtn" title="Validate offer string">Validate</button>
                </div>
                <small class="form-text text-muted">
                    Your CLINK offer string from ShockWallet, Lightning.Pub, or any CLINK-compatible wallet.
                    Generate this in your wallet under <strong>Receive &gt; <a href="https://my.shockwallet.app/offers" target+"_blank">Static Offers</a></strong>.
                </small>
                <div id="NofferValidation" class="mt-1"></div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="Title"></label>
                        <input asp-for="Title" class="form-control" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="InvoiceTimeout"></label>
                        <input asp-for="InvoiceTimeout" class="form-control" type="number" min="60" max="3600" />
                        <small class="form-text text-muted">Seconds before the invoice expires (default: 600).</small>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Description"></label>
                <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                <small class="form-text text-muted">Description shown to customers at checkout.</small>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="PollInterval"></label>
                        <input asp-for="PollInterval" class="form-control" type="number" min="2000" max="30000" />
                        <small class="form-text text-muted">Milliseconds between payment status checks (default: 5000).</small>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="AdditionalRelays"></label>
                <textarea asp-for="AdditionalRelays" class="form-control" rows="2" placeholder="wss://relay.example.com"></textarea>
                <small class="form-text text-muted">Optional: additional Nostr relays for redundancy (one per line).</small>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Save Configuration</button>
                <a asp-controller="UIStores" asp-action="Index" asp-route-storeId="@storeId" class="btn btn-secondary ms-2">Back to Store</a>
            </div>
        </form>
    </div>

    <div class="col-xl-4 col-lg-10 mt-4 mt-lg-0">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Setup Guide</h5>
            </div>
            <div class="card-body">
                <h6>Generating a CLINK Offer</h6>
                <hr class="my-2" />

                <p class="fw-semibold mb-1">ShockWallet (mobile/desktop)</p>
                <ol class="ps-3 small">
                    <li>Open <a href="https://ShockWallet.app" target="_blank">ShockWallet.app</a> in your browser or mobile app</li>
                    <li>Go to <strong>Menu &gt; Static Offers</strong></li>
                    <li>Copy the <code>nOffer1...</code> string</li>
                    <li>Paste it into the field above</li>
                </ol>

                <p class="fw-semibold mb-1 mt-3">Lightning.Pub (self-hosted node)</p>
                <ol class="ps-3 small">
                    <li>Log into your <a href="https://Lightning.Pub" target="_blank">Lightning.Pub</a> dashboard</li>
                    <li>Navigate to <strong>Offers</strong></li>
                    <li>Copy the generated <code>nOffer1...</code> string</li>
                    <li>Paste it into the field above</li>
                </ol>

                <p class="fw-semibold mb-1 mt-3">Electrum Wallet</p>
                <ol class="ps-3 small">
                    <li>Open Electrum wallet</li>
                    <li>Install <a href="https://github.com/BareBits/electrum_clink" target="_blank">CLINK/noffer plugin for electrum</a></li>
                    <li>Go to <strong>Electrum &gt; CLINK</strong> tab</li>
                    <li>Create and Copy the <code>nOffer...</code> string</li>
                    <li>Paste it into the field above</li>
                </ol>

                <hr class="my-3" />

                <h6>How It Works</h6>
                <ol class="ps-3 small">
                    <li>You generate a <code>nOffer1...</code> from your CLINK wallet</li>
                    <li>Customer checks out and selects "Lightning (CLINK)"</li>
                    <li>The plugin requests a BOLT11 invoice from your node over Nostr</li>
                    <li>Customer scans the QR and pays with any Lightning wallet</li>
                    <li>Payment is confirmed via CLINK receipt</li>
                </ol>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model?.Noffer))
        {
            <div class="card mt-3">
                <div class="card-header">
                    <h5 class="mb-0">Connection Status</h5>
                </div>
                <div class="card-body">
                    <p class="mb-1">
                        <span class="badge bg-success">Offer Configured</span>
                    </p>
                    <p class="small text-muted mb-0">
                        Your CLINK offer is set up. The system will use it to generate Lightning invoices at checkout.
                    </p>
                </div>
            </div>
        }
    </div>
</div>

@section PageFootContent {
    <script>
        document.getElementById('ValidateNofferBtn')?.addEventListener('click', async function() {
            const input = document.getElementById('NofferInput');
            const validation = document.getElementById('NofferValidation');
            const noffer = input?.value?.trim();

            if (!noffer) {
                validation.innerHTML = '<span class="text-warning">Please enter a noffer string first.</span>';
                return;
            }

            if (!noffer.startsWith('noffer1')) {
                validation.innerHTML = '<span class="text-danger">Invalid: must start with "noffer1".</span>';
                return;
            }

            if (noffer.length < 60) {
                validation.innerHTML = '<span class="text-danger">Invalid: string is too short (expected 60+ characters).</span>';
                return;
            }

            validation.innerHTML = '<span class="text-success"><i class="fa fa-check-circle"></i> Offer string format looks valid.</span>';
        });

        document.getElementById('NofferInput')?.addEventListener('input', function() {
            const validation = document.getElementById('NofferValidation');
            validation.innerHTML = '';
        });
    </script>
}
